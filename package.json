{
  "name": "nextjs-typescript-saas",
  "version": "1.0.0",
  "description": "Next.js TypeScript SaaS Starter",
  "keywords": [
    "nextjs",
    "oxfmt",
    "oxlint",
    "precommit",
    "react",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/Biboswan/bibotecture-landing2"
  },
  "license": "MIT",
  "author": "Biboswan Roy <biboswan98@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Biboswan/bibotecture-landing2"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "type-check": "tsc --pretty --noEmit",
    "prepare": "husky",
    "framer:export": "unframer adc980491d2c803a --outDir ./framer --jsx && node scripts/patch-framer-export.mjs"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@motionone/dom": "^10.13.1",
    "@motionone/easing": "^10.14.0",
    "@next/mdx": "^16.2.6",
    "akar-icons": "^1.9.31",
    "class-variance-authority": "^0.7.1",
    "lenis": "^1.1.2",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-view-transitions": "^0.3.5",
    "nodemailer": "^8.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "unframer": "4.1.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.json": "oxfmt"
  },
  "volta": {
    "node": "24.14.0"
  }
}
